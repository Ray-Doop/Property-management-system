page {
  background-color: #f0f2f5;
  --primary-gradient: linear-gradient(135deg, #005bea 0%, #00c6fb 100%);
  --secondary-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  --text-dark: #1e293b;
  --text-gray: #64748b;
  --text-light: #94a3b8;
  --white: #ffffff;
  --shadow-sm: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.05), 0 2rpx 4rpx -1rpx rgba(0, 0, 0, 0.03);
  --shadow-md: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.05), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.025);
  --card-border-radius: 24rpx;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* --- Header Area --- */
.sticky-header {
  position: relative;
  z-index: 100;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 320rpx;
  background: var(--primary-gradient);
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  z-index: -1;
}

.page-title-area {
  padding: 20rpx 40rpx 0;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title-main {
  display: flex;
  flex-direction: column;
}

.title-text {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--white);
  letter-spacing: 1rpx;
}

.subtitle-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* --- Stats Card (Tabs) --- */
.stats-card {
  margin: 0 32rpx;
  background: var(--white);
  border-radius: var(--card-border-radius);
  box-shadow: var(--shadow-md);
  padding: 30rpx 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  position: relative;
  top: 10rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 10rpx 0;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-gray);
  margin-bottom: 8rpx;
  font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.active-num {
  color: #005bea;
  transform: scale(1.1);
  transition: all 0.3s ease;
}

.active-label {
  color: #005bea;
  font-weight: 600;
}

.stat-indicator {
  position: absolute;
  bottom: -10rpx;
  width: 30rpx;
  height: 6rpx;
  background: #005bea;
  border-radius: 3rpx;
}

.stat-divider {
  width: 2rpx;
  height: 40rpx;
  background: #e2e8f0;
}

/* --- List Container --- */
.list-container {
  flex: 1;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* --- Order Card --- */
.order-card {
  background: var(--white);
  border-radius: var(--card-border-radius);
  margin-bottom: 30rpx;
  padding: 0;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s;
  border: 1rpx solid #f1f5f9;
}

.order-card:active {
  transform: scale(0.99);
}

.card-decoration {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(0, 91, 234, 0.05) 0%, rgba(0, 198, 251, 0.05) 100%);
  border-radius: 50%;
}

.card-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f8fafc;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.priority-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.priority-badge.normal {
  background: #e0f2fe;
  color: #0284c7;
}
.priority-badge.normal .badge-dot {
  background: #0284c7;
}

.priority-badge.urgent {
  background: #fee2e2;
  color: #ef4444;
}
.priority-badge.urgent .badge-dot {
  background: #ef4444;
}

.order-id {
  font-size: 24rpx;
  color: var(--text-light);
  font-family: monospace;
}

.order-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.card-body {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.main-info {
  flex: 1;
  padding-right: 20rpx;
}

.category-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-dark);
  margin-bottom: 12rpx;
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-gray);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.status-icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-ring {
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-ring.pending {
  background: #fffbeb;
  color: #d97706;
  border: 1rpx solid #fef3c7;
}

.status-ring.processing {
  background: #eff6ff;
  color: #2563eb;
  border: 1rpx solid #dbeafe;
}

.status-ring.completed {
  background: #f0fdf4;
  color: #16a34a;
  border: 1rpx solid #dcfce7;
}

.card-footer {
  padding: 20rpx 32rpx;
  background: #f8fafc;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.location-info {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-gray);
}

.icon-loc {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #005bea 0%, #00c6fb 100%);
  padding: 10rpx 32rpx;
  border-radius: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0, 91, 234, 0.2);
}

/* --- Empty State --- */
.empty-state {
  padding-top: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-gray);
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: var(--text-light);
}

.bottom-spacer {
  height: 40rpx;
}