page {
  background-color: #f7f8fa;
  --text-main: #1f2937;
  --text-sub: #4b5563;
  --text-light: #9ca3af;
  --white: #ffffff;
  padding-bottom: 160rpx;
}

.container {
  display: flex;
  flex-direction: column;
}

/* --- Status Banner --- */
.status-banner {
  position: relative;
  padding: 48rpx 40rpx 64rpx; /* Extra bottom padding for overlap */
  color: white;
  overflow: hidden;
}

.bg-pending {
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
}

.bg-processing {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
}

.bg-completed {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.banner-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

.status-icon-area {
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.status-icon-text {
  font-size: 48rpx;
}

.status-text-area {
  flex: 1;
}

.banner-status {
  font-size: 44rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.banner-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* --- Content Body --- */
.content-body {
  padding: 0 32rpx;
  margin-top: -32rpx; /* Overlap banner */
  position: relative;
  z-index: 3;
}

.card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  border-left: 8rpx solid #3b82f6;
  padding-left: 16rpx;
  line-height: 1.2;
}

/* --- Info Grid --- */
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.info-block {
  flex: 1;
  min-width: 40%;
  display: flex;
  flex-direction: column;
}

.info-block.full-width {
  flex-basis: 100%;
}

.info-block .label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
}

.info-block .value {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
  line-height: 1.4;
}

/* --- Contact Card --- */
.contact-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.contact-avatar-wrapper {
  margin-right: 24rpx;
}

.contact-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%);
  color: #4338ca;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.contact-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
  margin-bottom: 12rpx;
}

.address-line {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-sub);
}

.icon-small {
  margin-right: 8rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

.call-btn-circle {
  width: 88rpx;
  height: 88rpx;
  background: #ecfdf5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(16, 185, 129, 0.15);
  margin-left: 20rpx;
}

.call-btn-circle:active {
  background: #d1fae5;
  transform: scale(0.95);
}

.phone-icon {
  font-size: 40rpx;
}

/* --- Evaluation --- */
.score-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-big {
  font-size: 64rpx;
  font-weight: 800;
  color: #f59e0b;
  line-height: 1;
  margin-bottom: 12rpx;
}

.stars-row {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 32rpx;
  color: #e5e7eb;
}

.star.active {
  color: #f59e0b;
}

.eval-content-box {
  position: relative;
  background: #fffbeb;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  color: #92400e;
  font-size: 28rpx;
  line-height: 1.6;
}

.quote-icon {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  font-size: 60rpx;
  color: rgba(245, 158, 11, 0.2);
  font-family: serif;
  line-height: 1;
}

.reply-section {
  border-top: 1rpx dashed #e5e7eb;
  padding-top: 24rpx;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.my-reply-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #3b82f6;
  background: #eff6ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.reply-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.reply-content {
  font-size: 28rpx;
  color: var(--text-sub);
}

.empty-eval {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-light);
}

/* --- Buttons --- */
.full-width-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  margin-top: 32rpx;
}

.primary-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.3);
}

.primary-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* --- Bottom Bar --- */
.bottom-bar-wrapper {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: white;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  z-index: 99;
}

.bottom-float-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: white;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  box-shadow: 0 8rpx 20rpx rgba(37, 99, 235, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-float-btn:active {
  transform: scale(0.98);
}

/* --- Image Grid (Same as before but tweaked) --- */
.img-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.img-item {
  position: relative;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f3f4f6;
}

.img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.remove {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  color: white;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 12rpx;
}

.img-add {
  position: relative;
  padding-top: 100%;
  border: 2rpx dashed #d1d5db;
  border-radius: 12rpx;
  background: #f9fafb;
}

.add-icon {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, 0);
  font-size: 48rpx;
  color: #9ca3af;
}

.add-text {
  position: absolute;
  bottom: 20%;
  left: 50%;
  transform: translate(-50%, 0);
  font-size: 22rpx;
  color: #9ca3af;
}
