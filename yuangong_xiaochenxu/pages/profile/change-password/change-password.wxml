<view class="pwd-page">
  <view class="pwd-hero">
    <text class="pwd-title">修改密码</text>
    <text class="pwd-sub">为了账号安全，请定期更新密码</text>
  </view>

  <view class="pwd-card">
    <view class="input-row">
      <text class="input-label">旧密码</text>
      <input class="input" type="password" password="true" placeholder="请输入旧密码" bindinput="onOldPasswordInput" />
    </view>
    <view class="input-row">
      <text class="input-label">新密码</text>
      <input class="input" type="password" password="true" placeholder="请输入新密码" bindinput="onNewPasswordInput" />
    </view>
    <view class="input-row">
      <text class="input-label">确认新密码</text>
      <input class="input" type="password" password="true" placeholder="请再次输入新密码" bindinput="onConfirmPasswordInput" />
    </view>
  </view>

  <view class="tip-card">
    <text class="tip-title">安全建议</text>
    <text class="tip-item">密码建议 8 位以上，包含数字与字母</text>
    <text class="tip-item">不要与旧密码相同，避免使用生日等信息</text>
  </view>

  <view class="save-bar">
    <button class="btn-save" bindtap="handleChangePassword">确认修改</button>
  </view>
</view>
