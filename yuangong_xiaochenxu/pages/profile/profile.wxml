<view class="profile-page">
  <view class="profile-hero">
    <view class="hero-top">
      <text class="hero-title">个人中心</text>
      <text class="hero-sub">员工信息与账号安全</text>
    </view>
    <view class="hero-card">
      <view class="avatar-wrap" bindtap="chooseAvatar">
        <image class="avatar" src="{{avatarSrc}}" mode="aspectFill"></image>
        <view class="avatar-badge">更换</view>
      </view>
      <view class="hero-info">
        <text class="hero-name">{{employee.nickname || employee.name || '未命名'}}</text>
        <text class="hero-role">{{employee.permission || '未设置岗位'}}</text>
      </view>
    </view>
  </view>

  <view class="card info-card">
    <view class="card-title">基本资料</view>
    <view class="info-row">
      <text class="label">昵称</text>
      <input class="input" value="{{nicknameInput}}" bindinput="bindNicknameInput" placeholder="请输入昵称" />
    </view>
    <view class="info-row">
      <text class="label">手机号</text>
      <text class="value">{{employee.phone || '未设置'}}</text>
    </view>
    <view class="info-row">
      <text class="label">岗位</text>
      <text class="value">{{employee.permission || '未设置'}}</text>
    </view>
    <view class="info-row">
      <text class="label">擅长领域</text>
      <text class="value">{{employee.specialty || '未设置'}}</text>
    </view>
  </view>

  <view class="card action-card">
    <view class="action-item" bindtap="goToChangePassword">
      <view class="action-left">
        <text class="action-icon">🔒</text>
        <text class="action-text">修改密码</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="save-bar">
    <button class="btn-save" bindtap="saveProfile" loading="{{saving}}" disabled="{{saving}}">保存资料</button>
  </view>
</view>
