<view class="container">
  <view class="header">
    <view class="header-text">
      <text class="title">公告管理</text>
      <text class="subtitle">发布与查看最新公告</text>
    </view>
    <view class="add-btn" bindtap="goToAdd">
      <text class="icon">+</text>
      <text>发布</text>
    </view>
  </view>

  <scroll-view scroll-y class="list-container" bindscrolltolower="onReachBottom" enable-flex>
    <block wx:if="{{list.length > 0}}">
      <view class="card" wx:for="{{list}}" wx:key="noticeId" bindtap="goToDetail" data-id="{{item.noticeId}}">
        <view class="card-header">
          <text class="card-title">{{item.title}}</text>
          <view class="status-tag {{item.status == 1 ? 'published' : (item.status == 2 ? 'pending' : 'draft')}}">
            {{item.status == 1 ? '已发布' : (item.status == 2 ? '审核中' : '草稿')}}
          </view>
        </view>
        <view class="card-content">{{item.content}}</view>
        <view class="card-footer">
          <text class="publisher">{{item.publisherName || '管理员'}}</text>
          <text class="time">{{item.publishTime}}</text>
        </view>
      </view>
    </block>
    
    <view class="empty-state" wx:else>
      <image src="/assets/images/empty.png" mode="aspectFit" class="empty-img"></image>
      <text class="empty-text">暂无公告</text>
    </view>
    
    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
    
    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
