<view class="container">
  <view class="header-bg"></view>
  <view class="content">
    <view class="header">
      <view class="logo-text">WORK</view>
      <text class="title">智慧物业员工端</text>
      <text class="subtitle">Efficient Service · Convenient Management</text>
    </view>

    <view class="form-card">
      <view class="welcome-text">欢迎登录</view>
      
      <view class="input-group">
        <view class="input-item {{isUserFocus ? 'focus' : ''}}">
          <view class="icon">👤</view>
          <input class="input" 
            placeholder="请输入员工工号/账号" 
            model:value="{{username}}" 
            bindfocus="onUserFocus"
            bindblur="onUserBlur"
          />
        </view>
        <view class="input-item {{isPwdFocus ? 'focus' : ''}}">
          <view class="icon">🔒</view>
          <input class="input" 
            password 
            placeholder="请输入登录密码" 
            model:value="{{password}}" 
            bindfocus="onPwdFocus"
            bindblur="onPwdBlur"
          />
        </view>
      </view>

      <button class="btn-login" bindtap="handleLogin" hover-class="btn-hover">立即登录</button>
    </view>
    
  </view>
</view>
