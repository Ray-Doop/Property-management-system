page {
  background-color: #f4f6fb;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
}

.container {
  position: relative;
  min-height: 100vh;
  width: 100%;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 42vh;
  background: linear-gradient(135deg, #6a5cff 0%, #4d9cff 60%, #38bdf8 100%);
  border-bottom-left-radius: 80rpx;
  border-bottom-right-radius: 80rpx;
  z-index: 0;
  box-shadow: 0 20rpx 40rpx rgba(77, 156, 255, 0.25);
}

.content {
  position: relative;
  z-index: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
  color: #fff;
}

.logo-text {
  font-size: 52rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
  padding: 10rpx 26rpx;
  display: inline-block;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.18);
}

.title {
  font-size: 42rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.85;
  letter-spacing: 1rpx;
}

.form-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 32rpx;
  padding: 56rpx 40rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.welcome-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #0f172a;
  margin-bottom: 46rpx;
  text-align: left;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f7f8fc;
  border-radius: 18rpx;
  padding: 0 26rpx;
  height: 96rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.input-item.focus {
  background: #fff;
  border-color: #5b8cff;
  box-shadow: 0 8rpx 18rpx rgba(91, 140, 255, 0.18);
}

.icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  margin-right: 18rpx;
  background: #eaf0ff;
  color: #5b8cff;
}

.input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #0f172a;
}

.btn-login {
  background: linear-gradient(90deg, #5b8cff, #7a5cff);
  color: #fff;
  border-radius: 56rpx;
  height: 98rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin: 54rpx auto 0;
  display: block;
  width: 72%;
  padding: 0;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
  letter-spacing: 2rpx;
  box-shadow: 0 16rpx 34rpx rgba(90, 110, 255, 0.35);
  border: none;
}

.btn-hover {
  opacity: 0.92;
  transform: scale(0.98);
}
