/* pages/notice/add/add.wxss */
page {
  background-color: #f7f8fa;
  min-height: 100vh;
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
  padding-bottom: 180rpx; /* Space for footer */
}

.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}
.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.label-row .label {
  margin-bottom: 0;
}
.label-tip {
  font-size: 24rpx;
  color: #999999;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  border: 1rpx solid #e8e8e8;
}

.textarea {
  width: 100%;
  height: 400rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  border: 1rpx solid #e8e8e8;
  line-height: 1.6;
}

.placeholder {
  color: #bbbbbb;
}
.image-list {
  display: flex;
  flex-wrap: wrap;
}
.image-item {
  width: 150rpx;
  height: 150rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}
.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 34rpx;
  font-size: 24rpx;
}
.upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.plus {
  font-size: 60rpx;
  color: #bfbfbf;
  font-weight: 200;
}

.footer {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #ffffff;
  padding: 20rpx 30rpx calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  box-sizing: border-box;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1890ff, #0050b3);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  font-weight: 600;
  border: none;
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}
