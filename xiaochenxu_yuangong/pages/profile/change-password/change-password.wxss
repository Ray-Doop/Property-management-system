.pwd-page {
  min-height: 100vh;
  background: #f4f6fb;
  padding: 32rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.pwd-hero {
  margin-bottom: 24rpx;
}

.pwd-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
}

.pwd-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.pwd-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.input-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
  gap: 20rpx;
}

.input-row:last-child {
  border-bottom: none;
}

.input-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #64748b;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #0f172a;
  text-align: right;
  padding: 0;
}

.tip-card {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.06);
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 12rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -12rpx 24rpx rgba(15, 23, 42, 0.08);
}

.btn-save {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #111827, #1f2937);
  color: #ffffff;
}
