.change-password-container {
  background: var(--bg-color);
  min-height: 100vh;
  padding: 40rpx 30rpx;
}

.header-section {
  margin-bottom: 40rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-main);
  display: block;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.form-section {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: var(--card-shadow);
}

.input-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.input-item.no-border {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: var(--text-main);
  width: 160rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-main);
  height: 44rpx;
}

.placeholder {
  color: var(--text-placeholder);
}

.bottom-action {
  padding: 0 20rpx;
}

.btn-primary {
  background: var(--primary-color);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  height: 88rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 24rpx rgba(60, 127, 255, 0.28);
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}
