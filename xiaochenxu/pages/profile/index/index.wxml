<view class="container profile-container">
  <view class="header-card" bindtap="goToEdit">
    <image class="avatar" src="{{user.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
    <view class="info">
      <text class="nickname">{{user.nickname || '点击登录'}}</text>
      <text class="uid" wx:if="{{user}}">ID: {{user.userId}}</text>
      <text class="uid" wx:else>登录后享受更多权益</text>
    </view>
    <text class="arrow">></text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToEdit">
      <view class="item-left">
        <view class="icon-box bg-blue">
          <text class="iconfont">📝</text>
        </view>
        <text class="menu-text">修改资料</text>
      </view>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToChangePwd">
      <view class="item-left">
        <view class="icon-box bg-green">
          <text class="iconfont">🔒</text>
        </view>
        <text class="menu-text">修改密码</text>
      </view>
      <text class="arrow">></text>
    </view>
    
    <view class="menu-item logout" bindtap="logout" wx:if="{{user}}">
      <view class="item-left">
        <view class="icon-box bg-red">
          <text class="iconfont">🚪</text>
        </view>
        <text class="menu-text">退出登录</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>
  
  <view class="footer-version">当前版本 v1.0.0</view>
</view>
