<view class="home">
  <view class="hero">
    <view class="hero-top">
      <view class="brand-group">
        <text class="brand">智慧物业</text>
        <text class="brand-subtitle">让社区更安心</text>
      </view>
      <view class="hero-badge">服务中</view>
    </view>
    <view class="profile-card" bindtap="{{user ? 'navigateTo' : 'goToLogin'}}" data-url="/pages/profile/index/index">
      <image class="avatar" src="{{user.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
      <view class="profile-info">
        <block wx:if="{{user}}">
          <text class="nickname">{{user.nickname}}</text>
          <text class="welcome">欢迎回家</text>
        </block>
        <block wx:else>
          <text class="nickname">点击登录</text>
          <text class="welcome">登录后体验更多服务</text>
        </block>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section-card">
    <view class="section-header">
      <view class="section-title-group">
        <text class="section-title">快捷服务</text>
        <text class="section-desc">高频功能，一键直达</text>
      </view>
    </view>
    <view class="service-grid">
      <view class="service-item" bindtap="navigateTo" data-url="/pages/notice/list/list">
        <view class="service-icon bg-blue">
          <text class="iconfont">📢</text>
        </view>
        <text class="service-text">社区公告</text>
      </view>
      <view class="service-item" bindtap="navigateTo" data-url="/pages/repair/list/list">
        <view class="service-icon bg-orange">
          <text class="iconfont">🔧</text>
        </view>
        <text class="service-text">物业报修</text>
      </view>
      <view class="service-item" bindtap="navigateTo" data-url="/pages/pay/list/list">
        <view class="service-icon bg-green">
          <text class="iconfont">💰</text>
        </view>
        <text class="service-text">在线缴费</text>
      </view>
      <view class="service-item" bindtap="navigateTo" data-url="/pages/pass/index/index">
        <view class="service-icon bg-purple">
          <text class="iconfont">🚗</text>
        </view>
        <text class="service-text">出行码</text>
      </view>
      <view class="service-item" bindtap="switchTab" data-url="/pages/forum/index/index">
        <view class="service-icon bg-red">
          <text class="iconfont">💬</text>
        </view>
        <text class="service-text">邻里互动</text>
      </view>
      <view class="service-item" bindtap="switchTab" data-url="/pages/profile/index/index">
        <view class="service-icon bg-cyan">
          <text class="iconfont">👤</text>
        </view>
        <text class="service-text">个人中心</text>
      </view>
    </view>
  </view>

  <view class="notice-section" wx:if="{{latestNotice}}">
    <view class="section-header">
      <view class="section-title-group">
        <text class="section-title">最新动态</text>
        <text class="section-desc">社区公告与通知</text>
      </view>
      <view class="more-box" bindtap="navigateTo" data-url="/pages/notice/list/list">
        <text class="more">全部</text>
        <text class="iconfont icon-arrow">></text>
      </view>
    </view>
    <view class="notice-card" bindtap="navigateTo" data-url="/pages/notice/detail/detail?id={{latestNotice.noticeId}}">
      <view class="notice-tag">公告</view>
      <view class="notice-body">
        <text class="notice-title">{{latestNotice.title}}</text>
        <text class="notice-time">{{latestNotice.publishTime}}</text>
      </view>
    </view>
  </view>
</view>
