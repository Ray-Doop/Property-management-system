.container {
  padding: 30rpx;
  background-color: var(--bg-color);
  min-height: 100vh;
}

.form-group {
  background: var(--card-bg);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--card-shadow);
}

.label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.picker {
  font-size: 30rpx;
  color: var(--text-main);
}

.textarea {
  width: 100%;
  height: 200rpx;
  font-size: 30rpx;
  color: var(--text-main);
}

.input {
  font-size: 30rpx;
  color: var(--text-main);
  width: 100%;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin: 30rpx 0 20rpx 10rpx;
}

.row-inputs {
  display: flex;
  align-items: center;
}

.date-time-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.date-time-item {
  padding: 8rpx 0;
}

.input.mini {
  width: 100rpx;
  text-align: center;
  border-bottom: 1rpx solid var(--border-color);
}

.suffix {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin: 0 20rpx 0 10rpx;
}

.btn-submit {
  margin-top: 60rpx;
  background-color: var(--primary-color);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  box-shadow: 0 12rpx 24rpx rgba(60, 127, 255, 0.28);
}

/* Priority Radio Group Styles */
.radio-group {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.radio {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: var(--text-main);
  margin-right: 40rpx;
}

.radio .wx-radio-input {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.radio .wx-radio-input-checked {
  border-color: var(--primary-color);
  background-color: var(--primary-color);
}

/* Date Picker Styles */
.picker {
  font-size: 30rpx;
  color: var(--text-main);
  border-bottom: 1rpx solid var(--border-color);
  padding-bottom: 8rpx;
}

/* Image Upload Styles */
.image-list {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 150rpx;
  height: 150rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.video-thumb {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #2f2f2f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-icon {
  color: #fff;
  font-size: 46rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 34rpx;
  font-size: 24rpx;
}

.upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plus {
  font-size: 60rpx;
  color: var(--text-secondary);
  font-weight: 200;
}

.video-preview-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.video-preview-card {
  width: 90vw;
  height: 65vh;
  position: relative;
  background: #000;
  border-radius: 16rpx;
  overflow: hidden;
}

.video-preview-card video {
  width: 100%;
  height: 100%;
}

.video-preview-close {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  text-align: center;
  line-height: 60rpx;
  font-size: 40rpx;
  z-index: 2;
}
