<view class="forum-page">
  <view class="forum-header">
    <view class="header-top">
      <view class="header-title">社区广场</view>
      <view class="header-action" bindtap="goToPublish">发布</view>
    </view>
    <view class="header-sub">发现邻里新鲜事</view>
    <view class="search-shell">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索帖子标题"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="handleSearch"
        confirm-type="search"
      />
      <view class="search-btn" bindtap="handleSearch">搜索</view>
    </view>
  </view>

  <view class="section-bar">
    <scroll-view class="section-scroll" scroll-x show-scrollbar="{{false}}">
      <view class="section-pill {{selectedSectionId === 0 ? 'active' : ''}}" bindtap="selectSection" data-id="0">全部</view>
      <view class="section-pill {{selectedSectionId === item.sectionId ? 'active' : ''}}" wx:for="{{sections}}" wx:key="sectionId" bindtap="selectSection" data-id="{{item.sectionId}}">{{item.sectionName}}</view>
    </scroll-view>
  </view>

  <view class="forum-tabs">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="changeTab" data-tab="all">全部</view>
    <view class="tab-item {{currentTab === 'myPosts' ? 'active' : ''}}" bindtap="changeTab" data-tab="myPosts">我的帖子</view>
    <view class="tab-item {{currentTab === 'myComments' ? 'active' : ''}}" bindtap="changeTab" data-tab="myComments">我的评论</view>
  </view>

  <block wx:if="{{currentTab === 'all'}}">
    <block wx:if="{{list.length > 0}}">
      <view class="feed-card" wx:for="{{list}}" wx:key="postId" bindtap="goToDetail" data-id="{{item.postId}}">
        <view class="feed-head">
          <image class="feed-avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
          <view class="feed-meta">
            <view class="feed-name-row">
              <text class="feed-name">{{item.nickname}}</text>
              <text class="feed-role">{{item.authorType || '业主'}}</text>
            </view>
            <text class="feed-time">{{item.createdTime}}</text>
          </view>
          <view class="feed-tags" wx:if="{{item.isTop == 1 || item.isEssence == 1}}">
            <text class="tag-pill tag-top" wx:if="{{item.isTop == 1}}">置顶</text>
            <text class="tag-pill tag-essence" wx:if="{{item.isEssence == 1}}">精华</text>
          </view>
        </view>
        
        <view class="feed-body">
          <text class="feed-title" wx:if="{{item.title}}">{{item.title}}</text>
          <text class="feed-content">{{item.content}}</text>
          <view class="feed-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              class="image-item {{item.images.length === 1 ? 'image-single' : ''}}"
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:key="url"
              src="{{img.url}}"
              mode="aspectFill"
              catchtap="previewImage"
              data-urls="{{item.images}}"
              data-current="{{img.url}}"
            ></image>
          </view>
        </view>

        <view class="feed-footer">
          <view class="stat">
            <text class="iconfont">👁</text>
            <text class="count">{{item.collectCount || 0}}</text>
          </view>
          <view class="stat">
            <text class="iconfont">💬</text>
            <text class="count">{{item.commentCount || 0}}</text>
          </view>
          <view class="stat">
            <text class="iconfont">👍</text>
            <text class="count">{{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
      
      <view class="loading-more" wx:if="{{loading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="no-more" wx:if="{{!hasMore && !loading}}">
        <text class="no-more-text">没有更多内容了</text>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <image class="empty-img" src="/assets/qr-placeholder.png" mode="aspectFit"></image>
      <text class="empty-title">暂无帖子</text>
      <text class="empty-text">发布第一条邻里动态，分享新鲜事</text>
      <view class="empty-action" bindtap="goToPublish">去发布</view>
    </view>
  </block>

  <block wx:elif="{{currentTab === 'myPosts'}}">
    <block wx:if="{{myPosts.length > 0}}">
      <view class="feed-card" wx:for="{{myPosts}}" wx:key="postId" bindtap="goToDetail" data-id="{{item.postId}}">
        <view class="feed-head">
          <image class="feed-avatar" src="{{item.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
          <view class="feed-meta">
            <view class="feed-name-row">
              <text class="feed-name">{{item.nickname}}</text>
              <text class="feed-role">{{item.authorType || '业主'}}</text>
            </view>
            <text class="feed-time">{{item.createdTime}}</text>
          </view>
        </view>
        
        <view class="feed-body">
          <text class="feed-title" wx:if="{{item.title}}">{{item.title}}</text>
          <text class="feed-content">{{item.content}}</text>
          <view class="feed-images" wx:if="{{item.images && item.images.length > 0}}">
            <image
              class="image-item {{item.images.length === 1 ? 'image-single' : ''}}"
              wx:for="{{item.images}}"
              wx:for-item="img"
              wx:key="url"
              src="{{img.url}}"
              mode="aspectFill"
              catchtap="previewImage"
              data-urls="{{item.images}}"
              data-current="{{img.url}}"
            ></image>
          </view>
        </view>

        <view class="feed-footer">
          <view class="stat">
            <text class="iconfont">👁</text>
            <text class="count">{{item.collectCount || 0}}</text>
          </view>
          <view class="stat">
            <text class="iconfont">💬</text>
            <text class="count">{{item.commentCount || 0}}</text>
          </view>
          <view class="stat">
            <text class="iconfont">👍</text>
            <text class="count">{{item.likeCount || 0}}</text>
          </view>
          <view class="stat danger-pill" catchtap="deletePost" data-id="{{item.postId}}">
            <text class="iconfont">🗑</text>
            <text class="count">删除</text>
          </view>
        </view>
      </view>
      
      <view class="loading-more" wx:if="{{myPostLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="no-more" wx:if="{{!myPostHasMore && !myPostLoading}}">
        <text class="no-more-text">没有更多内容了</text>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <image class="empty-img" src="/assets/qr-placeholder.png" mode="aspectFit"></image>
      <text class="empty-title">暂无我的帖子</text>
      <text class="empty-text">分享生活动态，让邻里认识你</text>
      <view class="empty-action" bindtap="goToPublish">去发布</view>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{myComments.length > 0}}">
      <view class="comment-card" wx:for="{{myComments}}" wx:key="commentId">
        <view class="comment-card-header">
          <text class="comment-post-title">{{item.postTitle || '帖子详情'}}</text>
          <text class="comment-time">{{item.createdTime}}</text>
        </view>
        <text class="comment-content">{{item.content}}</text>
        <view class="comment-post-preview" wx:if="{{item.postContent}}">
          <text class="comment-post-text">{{item.postContent}}</text>
        </view>
        <view class="comment-actions">
          <view class="action-pill ghost-pill" bindtap="goToDetail" data-id="{{item.postId}}">查看帖子</view>
          <view class="action-pill danger-pill" catchtap="deleteComment" data-id="{{item.commentId}}">删除</view>
        </view>
      </view>
      
      <view class="loading-more" wx:if="{{myCommentLoading}}">
        <text class="loading-text">加载中...</text>
      </view>
      <view class="no-more" wx:if="{{!myCommentHasMore && !myCommentLoading}}">
        <text class="no-more-text">没有更多内容了</text>
      </view>
    </block>

    <view class="empty-state" wx:else>
      <image class="empty-img" src="/assets/qr-placeholder.png" mode="aspectFit"></image>
      <text class="empty-title">暂无我的评论</text>
      <text class="empty-text">参与讨论，让邻里看到你的观点</text>
    </view>
  </block>
</view>
