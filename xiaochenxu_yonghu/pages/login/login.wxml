<view class="container login-container">
  <view class="header-section">
    <view class="logo-box">
      <image class="logo" src="/assets/default-avatar.png" mode="aspectFit"></image>
    </view>
    <text class="app-name">智慧物业</text>
    <text class="slogan">让生活更美好</text>
  </view>

  <view class="form-section">
    <view class="input-item">
      <input class="input" type="text" placeholder="用户名/手机号" placeholder-class="placeholder" model:value="{{username}}" />
    </view>
    
    <view class="input-item">
      <input class="input" type="password" password="true" placeholder="请输入密码" placeholder-class="placeholder" model:value="{{password}}" />
    </view>
    
    <view class="input-item captcha-item">
      <input class="input" type="text" placeholder="验证码" placeholder-class="placeholder" model:value="{{captchaCode}}" />
      <image class="captcha-img" src="{{captchaImage}}" bindtap="refreshCaptcha" mode="aspectFit"></image>
    </view>

    <view class="action-links">
      <text bindtap="goToRegister">注册账号</text>
      <text>忘记密码</text>
    </view>

    <button class="btn-login" bindtap="handleLogin" hover-class="btn-hover">登 录</button>
    
    <view class="divider">
      <view class="line"></view>
      <text>其他登录方式</text>
      <view class="line"></view>
    </view>

    <button class="btn-wechat" bindtap="handleWeChatLogin" hover-class="btn-hover">
      <text class="iconfont">💬</text> 微信一键登录
    </button>
  </view>
</view>
