.container {
  padding: 30rpx;
  background: var(--bg-color);
  min-height: 100vh;
}

.header {
  border-bottom: 1rpx solid var(--border-color);
  padding-bottom: 30rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
  margin-bottom: 20rpx;
  display: block;
}

.meta {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: flex;
  justify-content: space-between;
}

.content {
  font-size: 30rpx;
  color: var(--text-content);
  line-height: 1.6;
  margin-bottom: 40rpx;
  white-space: pre-wrap;
}

.attachments {
  border-top: 1rpx solid var(--border-color);
  padding-top: 30rpx;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}

.iconfont {
  margin-right: 10rpx;
  font-size: 32rpx;
}

.filename {
  font-size: 28rpx;
  color: var(--primary-color);
}
