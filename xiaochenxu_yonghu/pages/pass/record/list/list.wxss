.container {
  padding: 20rpx;
  background-color: var(--bg-color);
  min-height: 100vh;
}

.record-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--card-shadow);
}

.record-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.time {
  font-size: 28rpx;
  color: var(--text-main);
}

.status {
  font-size: 26rpx;
  font-weight: bold;
}

.status-ISSUED { color: var(--primary-color); }
.status-ENTERED { color: var(--warning-color); }
.status-EXITED { color: var(--text-secondary); }

.record-content .row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.value {
  font-size: 26rpx;
  color: var(--text-main);
}

.fee {
  color: #ff4d4f;
  font-weight: bold;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 30rpx;
  color: var(--text-placeholder);
  font-size: 26rpx;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  display: block;
  margin: 100rpx auto 20rpx;
}
