.container {
  padding: 20rpx;
  background-color: var(--bg-color);
  min-height: 100vh;
}

.header-action {
  padding: 0 0 20rpx;
}

.btn-submit {
  background: var(--primary-gradient);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  width: 100%;
  box-shadow: 0 12rpx 24rpx rgba(60, 127, 255, 0.28);
}

.repair-item {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--card-shadow);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.category {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-main);
}

.status {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.status-pending { background: rgba(250, 140, 22, 0.1); color: var(--warning-color); }
.status-processing { background: rgba(24, 144, 255, 0.1); color: var(--info-color); }
.status-done { background: rgba(82, 196, 26, 0.1); color: var(--primary-color); }
.status-cancel { background: #f5f5f5; color: var(--text-secondary); }

.item-content {
  font-size: 28rpx;
  color: var(--text-content);
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.5;
}

.item-footer {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-top: 1rpx solid var(--border-color);
  padding-top: 16rpx;
}

.loading, .no-more, .empty {
  text-align: center;
  padding: 30rpx;
  color: var(--text-placeholder);
  font-size: 26rpx;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  display: block;
  margin: 100rpx auto 20rpx;
}
