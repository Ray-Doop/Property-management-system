<view class="container change-password-container">
  <view class="header-section">
    <text class="page-title">修改密码</text>
    <text class="page-desc">请输入您的旧密码和新密码</text>
  </view>

  <view class="form-section">
    <view class="input-item">
      <text class="label">旧密码</text>
      <input class="input" type="password" password="true" placeholder="请输入旧密码" placeholder-class="placeholder" model:value="{{oldPassword}}" />
    </view>
    
    <view class="input-item">
      <text class="label">新密码</text>
      <input class="input" type="password" password="true" placeholder="请输入新密码" placeholder-class="placeholder" model:value="{{newPassword}}" />
    </view>
    
    <view class="input-item no-border">
      <text class="label">确认新密码</text>
      <input class="input" type="password" password="true" placeholder="再次输入新密码" placeholder-class="placeholder" model:value="{{confirmPassword}}" />
    </view>
  </view>

  <view class="bottom-action">
    <button class="btn-primary" bindtap="handleChangePassword" hover-class="btn-hover">确认修改</button>
  </view>
</view>