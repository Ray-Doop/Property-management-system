<view class="container register-container">
  <view class="header-section">
    <text class="page-title">注册账号</text>
    <text class="page-desc">请填写真实的业主信息以便审核</text>
  </view>

  <scroll-view scroll-y class="form-scroll">
    <!-- 基本信息 -->
    <view class="card form-card">
      <view class="card-title">基本信息</view>
      


      <view class="input-item">
        <text class="label">密码</text>
        <input class="input" type="password" password="true" placeholder="设置登录密码" placeholder-class="placeholder" model:value="{{password}}" />
      </view>
      
      <view class="input-item">
        <text class="label">确认密码</text>
        <input class="input" type="password" password="true" placeholder="再次输入密码" placeholder-class="placeholder" model:value="{{confirmPassword}}" />
      </view>

      <view class="input-item">
        <text class="label">昵称</text>
        <input class="input" type="text" placeholder="怎么称呼您" placeholder-class="placeholder" model:value="{{nickname}}" />
      </view>

      <view class="input-item no-border">
        <text class="label">手机号</text>
        <input class="input" type="number" maxlength="11" placeholder="联系手机号" placeholder-class="placeholder" model:value="{{phone}}" />
      </view>
    </view>

    <!-- 房产信息 -->
    <view class="card form-card">
      <view class="card-title">房产信息</view>
      
      <view class="house-inputs">
        <view class="mini-input-box">
          <input class="mini-input" type="number" placeholder="楼栋" model:value="{{buildingNo}}" />
          <text class="suffix">栋</text>
        </view>
        <view class="mini-input-box">
          <input class="mini-input" type="number" placeholder="单元" model:value="{{unitNo}}" />
          <text class="suffix">单元</text>
        </view>
        <view class="mini-input-box">
          <input class="mini-input" type="number" placeholder="房号" model:value="{{roomNo}}" />
          <text class="suffix">室</text>
        </view>
      </view>

      <view class="input-item no-border">
        <text class="label">房屋面积</text>
        <input class="input" type="digit" placeholder="建筑面积(㎡)" placeholder-class="placeholder" model:value="{{area}}" />
      </view>
    </view>

    <!-- 车辆信息 -->
    <view class="card form-card">
      <view class="card-title">车辆信息 (选填)</view>
      
      <view class="input-item no-border">
        <text class="label">车牌号</text>
        <input class="input" type="text" placeholder="如：京A88888" placeholder-class="placeholder" model:value="{{vehicleInfo}}" />
      </view>
    </view>
  </scroll-view>

  <view class="bottom-action">
    <button class="btn-primary" bindtap="handleRegister" hover-class="btn-hover">提交审核</button>
  </view>
</view>
